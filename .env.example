# --- Bot de Telegram ---
BOT_TOKEN=                      # obtenido de @BotFather

# --- Acceso restringido ---
ALLOWED_USER_ID=                # tu user_id numerico de Telegram (@userinfobot)

# --- Local Bot API Server ---
TELEGRAM_API_ID=                # de my.telegram.org
TELEGRAM_API_HASH=              # de my.telegram.org
TELEGRAM_API_BASE_URL=http://127.0.0.1:8081

# --- Almacenamiento temporal ---
# Opcional. Si se omite, usa <os.tmpdir()>/tg-media-fetcher.
# En Linux con tmpfs puedes apuntar a /mnt/ramdisk-downloads (opcional).
DOWNLOAD_TMP_DIR=

# --- yt-dlp / ffmpeg ---
YTDLP_PATH=yt-dlp               # o ruta absoluta si no esta en el PATH
FFMPEG_PATH=ffmpeg              # o ruta absoluta
